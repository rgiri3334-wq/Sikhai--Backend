# ============================================================
#  SIKAI — Environment Variables
#  Copy to .env and fill in your values
#  NEVER commit .env to git
# ============================================================

# --- App ---
APP_NAME="Sikai Learning API"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY="your-super-secret-key-change-this-in-production-min-32-chars"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1"

# --- Groq AI (FREE to start, then pay-as-you-go — cheapest LLM API) ---
# Get key: https://console.groq.com
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GROQ_MODEL_FAST="llama-3.1-8b-instant"        # For simple tasks (tutor chat)
GROQ_MODEL_SMART="llama-3.3-70b-versatile"    # For course generation, quizzes

# --- Supabase (FREE tier: 500MB DB, 1GB storage, 50k auth users) ---
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL="https://xxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJxxxxxxxxxxxxxxxxxxxxxxxx"
SUPABASE_SERVICE_KEY="eyJxxxxxxxxxxxxxxxxxxxxxxxx"  # Keep secret! Server-side only

# --- Upstash Redis (FREE tier: 10k requests/day) ---
# Get from: https://upstash.com
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- JWT ---
JWT_SECRET="another-secret-key-for-jwt-signing"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080    # 7 days

# --- AI Tutor Settings ---
MAX_TOKENS_COURSE=4000      # Max tokens per course generation
MAX_TOKENS_TUTOR=800        # Max tokens per tutor response
MAX_TOKENS_QUIZ=2000        # Max tokens per quiz generation
TUTOR_HISTORY_LIMIT=10      # How many past messages to keep in context

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30    # API calls per user per minute
RATE_LIMIT_AI_PER_HOUR=50   # AI generations per user per hour

# --- Cache TTLs (seconds) ---
CACHE_TTL_COURSE=86400      # 24 hours — generated courses
CACHE_TTL_QUIZ=3600         # 1 hour  — quizzes
CACHE_TTL_USER=300          # 5 min   — user profiles
